NEXT_PUBLIC_WEB_VERSION="1.1.2"

# ADMIN_PANEL URL
NEXT_PUBLIC_API_URL="https://elms.wrteam.me" # do not add '/' at the end


# WEBSITE URL
NEXT_PUBLIC_WEB_URL="https://elms-web.wrteam.me" # do not add '/' at the end

 
# MAIN LOADER COLOR
NEXT_PUBLIC_LOADER_COLOR="#5a5bb5"

# WEBSITE NAME
NEXT_PUBLIC_WEB_NAME="eLMS" # This field is must do not leave it as blank

# # VAPID KEY (This key you get from firebase and steps given in doc)
NEXT_PUBLIC_VAPID_KEY="xxxxxxxxxxxxxxxxxxxxxxx"

# FIREBASE (Compulsory configure this settings otherwise login will not work) 
NEXT_PUBLIC_API_KEY="xxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_AUTH_DOMAIN="xxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_PROJECT_ID="xxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STORAGE_BUCKET="xxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MESSAGING_SENDER_ID="xxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_APP_ID="xxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MEASUREMENT_ID="xxxxxxxxxxxxxxxxxxxxxxx"

# DEFAULT META TAGS (This is for seo metadata)
NEXT_PUBLIC_TITLE="eLMS - Online Learning Management System for Courses, Training & Skill Development" 
NEXT_PUBLIC_DESCRIPTION="eLMS is a modern learning management system that helps individuals, educators, and organizations create, manage, and sell online courses. Learn anytime, anywhere with expert instructors and interactive content."
NEXT_PUBLIC_KEYWORDS="eLMS, online learning, learning management system, LMS platform, sell courses online, e-learning platform, virtual training, instructor-led courses, student portal, course marketplace, Udemy alternative, online education, skill development, video courses, remote learning"

# SEO (Do not change)
NEXT_PUBLIC_SEO="true"

# API ENDPOINT (Do not change)
NEXT_PUBLIC_END_POINT="api"

# DEMO START (Do not change)
NEXT_PUBLIC_DEMO="false"

# Loading Min (Do not change)
NEXT_PUBLIC_LOAD_MIN=5

NEXT_PUBLIC_DEFAULT_COUNTRY_CODE=us
NEXT_PUBLIC_COUNTRY_DIAL_CODE=1

